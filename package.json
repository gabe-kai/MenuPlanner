  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:tests": "npm test -- --runInBand",
    "ci:check": "npm run lint && npm run lint:tests && npm run build",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev --name init-auth-identity",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push"
  },
  "keywords": [],
