generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AuthUserRole {
  ADULT
  CHILD
}

model AuthUser {
  id           String       @id @default(cuid())
  userId       String       @unique
  name         String
  role         AuthUserRole
  familyId     String       @default("fam-1")
  passwordHash String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
