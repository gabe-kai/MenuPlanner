#
# MenuPlanner - Auth + environment configuration
#

# Toggle for real auth mode:
# - false: existing mock session behavior
# - true: NextAuth-backed credential mode
NEXT_PUBLIC_USE_REAL_AUTH=false

# Required for NextAuth cookie/token stability across restarts in production.
NEXTAUTH_SECRET=changeme_secure_secret_here

# SQLite database location for Prisma (relative to `prisma/schema.prisma`).
DATABASE_URL="file:./dev.db"

# Optional in demo environments.
NEXT_PUBLIC_DEMO_AUTH_PASSWORD=menuplanner
NEXTAUTH_DEMO_PASSWORD=menuplanner

# Optional per-identity demo credential overrides for NextAuth credential mode.
# Example:
# {"mom":"p@ssword1","dad":"p@ssword2","sarah":"p@ssword3"}
NEXTAUTH_IDENTITY_CREDENTIALS={}

# Optional explicit admin allowlist for the application.
# Comma-separated list of lowercase user IDs.
MENU_ADMIN_USER_IDS=

# Register API (development bootstrap):
# POST /api/auth/register with { userId, name, role, password, familyId? }

# Recommended production deployment settings:
# - Set this to your production origin (required in deployed environments for auth cookies/callback URLs).
NEXTAUTH_URL=http://localhost:3000
# - Set true if NextAuth is behind a reverse proxy or non-local host.
NEXTAUTH_TRUST_HOST=true
# - Optional runtime debug logging for troubleshooting.
NEXTAUTH_DEBUG=false

